<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="atlasApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:atlasApp"
    FlyoutBackgroundColor="#1E1E2F">

    <Shell.FlyoutHeader>

        <Grid HeightRequest="220"
              BackgroundColor="#6D5BD0">

            <VerticalStackLayout
                VerticalOptions="Center"
                HorizontalOptions="Center">

                <Frame
                    WidthRequest="80"
                    HeightRequest="80"
                    CornerRadius="40"
                    BackgroundColor="White"
                    Padding="0">

                    <Label
                        Text="👤"
                        FontSize="40"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>

                </Frame>

                <Label
                    Text="Atlas User"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalOptions="Center"/>

                <Label
                    Text="atlas@company.com"
                    TextColor="White"
                    HorizontalOptions="Center"/>

            </VerticalStackLayout>

        </Grid>

    </Shell.FlyoutHeader>

    <FlyoutItem Title="Dashboard">
        <ShellContent
            Route="DashboardPage"
            ContentTemplate="{DataTemplate local:DashboardPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Profile">
        <ShellContent
            ContentTemplate="{DataTemplate local:ProfilePage}" />
    </FlyoutItem>

    <FlyoutItem Title="Settings">
        <ShellContent
            ContentTemplate="{DataTemplate local:SettingsPage}" />
    </FlyoutItem>

</Shell>