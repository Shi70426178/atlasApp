<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="atlasApp.DashboardPage"
    BackgroundColor="#121212">

    <VerticalStackLayout
        VerticalOptions="Center"
        HorizontalOptions="Center"
        Spacing="20">

        <Image
            Source="logo.png"
            HeightRequest="100"/>

        <Label
            Text="Dashboard"
            FontSize="32"
            FontAttributes="Bold"
            TextColor="White"/>

        <Label
            x:Name="lblWelcome"
            Text="Welcome User"
            FontSize="18"
            TextColor="LightGray"/>

    </VerticalStackLayout>

</ContentPage>