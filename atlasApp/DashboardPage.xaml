<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="atlasApp.DashboardPage"
    Title="Dashboard"
    BackgroundColor="{StaticResource BackgroundColor}">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="18">

            <!-- Header -->
            <VerticalStackLayout>

                <Label
                    x:Name="lblGreeting"
                    FontSize="16"
                    TextColor="{StaticResource TextSecondary}" />

                <Label
                    x:Name="lblWelcome"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextPrimary}" />

                <Label
                    Text="Track your shipments efficiently"
                    FontSize="14"
                    TextColor="{StaticResource TextSecondary}" />

            </VerticalStackLayout>

            <!-- Quick Actions -->
            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="15">

                <Border
                    WidthRequest="65"
                    HeightRequest="65"
                    BackgroundColor="#DBEAFE"
                    StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32"/>
                    </Border.StrokeShape>
                    <Label
    Text="➕"
    FontSize="24"
    HorizontalOptions="Center"
    VerticalOptions="Center">

                        <Label.GestureRecognizers>
                            <TapGestureRecognizer
            Tapped="CreatePost_Tapped"/>
                        </Label.GestureRecognizers>

                    </Label>
                </Border>

                <Border
                    WidthRequest="65"
                    HeightRequest="65"
                    BackgroundColor="#DBEAFE"
                    StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32"/>
                    </Border.StrokeShape>

                    <Label
                        Text="📦"
                        FontSize="24"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Border>

                <Border
                    WidthRequest="65"
                    HeightRequest="65"
                    BackgroundColor="#DBEAFE"
                    StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32"/>
                    </Border.StrokeShape>

                    <Label
                        Text="📅"
                        FontSize="24"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Border>

                <Border
                    WidthRequest="65"
                    HeightRequest="65"
                    BackgroundColor="#DBEAFE"
                    StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32"/>
                    </Border.StrokeShape>

                    <Label
                        Text="🔍"
                        FontSize="24"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Border>

            </HorizontalStackLayout>

            <!-- Hero Shipment Card -->
            <Border
                BackgroundColor="#2563EB"
                Padding="20"
                StrokeThickness="0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25"/>
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,Auto">

                    <VerticalStackLayout>

                        <Label
                            Text="Current Shipment"
                            TextColor="White"
                            FontSize="16"/>

                        <Label
                            Text="ATL-20458"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="White"/>

                        <Label
                            Text="Delhi → Mumbai"
                            TextColor="White"/>

                        <Label
                            Text="Arriving in 24 Minutes"
                            TextColor="#DBEAFE"/>

                    </VerticalStackLayout>

                    <Label
                        Grid.Column="1"
                        Text="🚚"
                        FontSize="70"/>

                </Grid>

            </Border>

            <!-- Statistics -->
            <Grid
                ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="10"
                RowSpacing="10">

                <Border
                    Style="{StaticResource DashboardCard}">

                    <VerticalStackLayout>
                        <Label
                            Text="124"
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="#2563EB"/>

                        <Label
                            Text="Total Shipments"/>
                    </VerticalStackLayout>

                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource DashboardCard}">

                    <VerticalStackLayout>
                        <Label
                            Text="45"
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="#F59E0B"/>

                        <Label
                            Text="In Transit"/>
                    </VerticalStackLayout>

                </Border>

                <Border
                    Grid.Row="1"
                    Style="{StaticResource DashboardCard}">

                    <VerticalStackLayout>
                        <Label
                            Text="58"
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="#10B981"/>

                        <Label
                            Text="Delivered"/>
                    </VerticalStackLayout>

                </Border>

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Style="{StaticResource DashboardCard}">

                    <VerticalStackLayout>
                        <Label
                            Text="21"
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="#EF4444"/>

                        <Label
                            Text="Delayed"/>
                    </VerticalStackLayout>

                </Border>

            </Grid>

            <!-- Recent Shipments -->
            <Label
                Text="Recent Shipment Updates"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="{StaticResource TextPrimary}" />

            <Border
                Style="{StaticResource DashboardCard}">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <VerticalStackLayout>

                    <Label
                        Text="Shipment ATL001 Delivered"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#10B981" />

                    <Label
                        Text="Delivered to Mumbai Distribution Center"
                        TextColor="{StaticResource TextSecondary}" />

                    <Label
                        Text="Today • 09:15 AM"
                        FontSize="12"
                        TextColor="#94A3B8" />

                </VerticalStackLayout>

            </Border>

            <Border
                Style="{StaticResource DashboardCard}">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <VerticalStackLayout>

                    <Label
                        Text="Shipment ATL002 In Transit"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#2563EB" />

                    <Label
                        Text="Departed from Delhi Warehouse"
                        TextColor="{StaticResource TextSecondary}" />

                    <Label
                        Text="Today • 08:30 AM"
                        FontSize="12"
                        TextColor="#94A3B8" />

                </VerticalStackLayout>

            </Border>

            <Border
                Style="{StaticResource DashboardCard}">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <VerticalStackLayout>

                    <Label
                        Text="Shipment ATL003 Delayed"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#EF4444" />

                    <Label
                        Text="Weather conditions causing route delay"
                        TextColor="{StaticResource TextSecondary}" />

                    <Label
                        Text="Yesterday • 06:45 PM"
                        FontSize="12"
                        TextColor="#94A3B8" />

                </VerticalStackLayout>

            </Border>

            <!-- Company Updates -->
            <Label
                Text="Company Updates"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="{StaticResource TextPrimary}" />

            <Border
                Style="{StaticResource DashboardCard}">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <VerticalStackLayout>

                    <Label
                        Text="🚀 New Shipment Tracking Module Released"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{StaticResource TextPrimary}" />

                    <Label
                        Text="Users can now monitor shipment movement in real-time with enhanced tracking and delivery visibility."
                        TextColor="{StaticResource TextSecondary}" />

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>