<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="atlasApp.SignupPage"
             BackgroundColor="#121212">

    <ScrollView>

        <VerticalStackLayout
            Padding="25"
            Spacing="18">

            <Image
                Source="logo.png"
                HeightRequest="100"
                HorizontalOptions="Center"/>

            <Label
                Text="Create Account"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalOptions="Center"/>

            <Border
                BackgroundColor="#1E1E1E"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20"
                Padding="20">   

                <VerticalStackLayout Spacing="15">

                    <Entry
                        x:Name="txtUserName"
                        Placeholder="User Name"
                        TextColor="White"
                        PlaceholderColor="Gray"/>

                    <Entry
                        x:Name="txtRole"
                        Placeholder="Role"
                        TextColor="White"
                        PlaceholderColor="Gray"/>

                    <Entry
                        x:Name="txtEmail"
                        Placeholder="Email"
                        Keyboard="Email"
                        TextColor="White"
                        PlaceholderColor="Gray"/>

                    <Entry
                        x:Name="txtPhone"
                        Placeholder="Phone Number"
                        Keyboard="Telephone"
                        TextColor="White"
                        PlaceholderColor="Gray"/>

                    <Entry
                        x:Name="txtBranch"
                        Placeholder="Company Branch"
                        TextColor="White"
                        PlaceholderColor="Gray"/>

                    <Entry
                        x:Name="txtPassword"
                        Placeholder="Password"
                        IsPassword="True"
                        TextColor="White"
                        PlaceholderColor="Gray"/>

                    <Button
                        Text="SIGN UP"
                        BackgroundColor="#28A745"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="50"
                        Clicked="OnSignupClicked"/>

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>

    </ScrollView>
</ContentPage>