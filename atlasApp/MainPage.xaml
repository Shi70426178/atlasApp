<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="atlasApp.MainPage"
             BackgroundColor="Black">

    <ScrollView>

        <VerticalStackLayout
            Padding="30"
            Spacing="25"
            VerticalOptions="Center">

            <Label
                Text="Atlas App"
                FontSize="36"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="Black" />

            <Label
                Text="Welcome"
                FontSize="22"
                HorizontalOptions="Center"
                TextColor="Gray" />

            <Frame
                CornerRadius="15"
                Padding="20"
                BackgroundColor="black"
                HasShadow="True">

                <VerticalStackLayout Spacing="20">

                    <Entry
                        x:Name="txtEmail"
                        Placeholder="Enter Email"
                        Keyboard="Email"
                        HeightRequest="50" />

                    <Entry
                        x:Name="txtPassword"
                        Placeholder="Enter Password"
                        IsPassword="True"
                        HeightRequest="50" />

                    <Button
                        Text="Login"
                        HeightRequest="50"
                        BackgroundColor="#2196F3"
                        TextColor="black"
                        CornerRadius="10"
                        Clicked="OnLoginClicked" />

                    <Button
                        Text="Signup"
                        HeightRequest="50"
                        BackgroundColor="#4CAF50"
                        TextColor="black"
                        CornerRadius="10"
                        Clicked="OnSignupClicked" />

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>