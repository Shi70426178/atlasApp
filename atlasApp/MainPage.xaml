<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="atlasApp.MainPage"
             BackgroundColor="#121212">

    <ScrollView>

        <VerticalStackLayout
            Padding="30"
            Spacing="20"
            VerticalOptions="Center">

            <!-- Company Logo -->
            <Image
                Source="logo.png"
                HeightRequest="120"
                WidthRequest="120"
                HorizontalOptions="Center"/>

            <!-- Company Name -->
            <Label
                Text="ATLAS APP"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalOptions="Center"/>

            <Label
                Text="Welcome Back"
                FontSize="18"
                TextColor="#B0B0B0"
                HorizontalOptions="Center"/>

            <!-- Login Card -->
            <Border
                StrokeThickness="0"
                BackgroundColor="#1E1E1E"
                StrokeShape="RoundRectangle 20"
                Padding="25">       

                <VerticalStackLayout Spacing="18">

                    <Entry
                        x:Name="txtUserId"
                        Placeholder="User ID"
                        PlaceholderColor="Gray"
                        TextColor="White"
                        BackgroundColor="#2A2A2A"
                        HeightRequest="50"/>

                    <Entry
                        x:Name="txtPassword"
                        Placeholder="Password"
                        PlaceholderColor="Gray"
                        TextColor="White"
                        BackgroundColor="#2A2A2A"
                        IsPassword="True"
                        HeightRequest="50"/>

                    <Button
                        Text="LOGIN"
                        HeightRequest="50"
                        BackgroundColor="#0078D7"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        Clicked="OnLoginClicked"/>

                    <Button
                        Text="Create Account"
                        HeightRequest="50"
                        BackgroundColor="#28A745"
                        TextColor="White"
                        CornerRadius="12"
                        Clicked="OnSignupClicked"/>

                </VerticalStackLayout>

            </Border>
        </VerticalStackLayout>

    </ScrollView>

</ContentPage>